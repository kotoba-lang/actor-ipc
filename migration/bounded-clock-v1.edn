{:schema "kotoba-actor-ipc-migration/v1"
 :profile :actor-ipc/bounded-clock-v1
 :legacy {:source "src/actor_ipc/time.cljc"
          :status :retained-general-oracle}
 :canonical {:engine-and-conformance "src/actor_ipc/bounded_clock.kotoba"}
 :domain
 {:functions [:make-clock :advance-clock :clock-tick :clock-tick-rate
              :clock-accumulator-ns :clock-alpha :wrap32]
  :algorithm "fixed-timestep accumulator game clock, originally
             kami-engine/kami-core's Rust GameClock (src/time.rs, deleted
             in kotoba-lang/kami-engine PR #82). tick_duration_ns =
             1e9/tick_rate; advance folds elapsed nanoseconds into the
             accumulator, emits floor(accumulator/tick_duration_ns)
             ticks, keeps the remainder, and wraps the tick counter at
             2^32 (matching the original Rust u32 wrapping_add)."
  :representation "clock-type is a fixed 4-field :record (:tick
                   :tick-rate :tick-duration-ns :accumulator-ns) instead
                   of the legacy open map -- every field always present,
                   same shape, no narrowing"}
 :excluded [:actor-ipc.actor :actor-ipc.ipc :actor-ipc/root-ns]
 :exclusion-reason "not reviewed this pass; time.cljc was self-contained
                    (no requires) and a clean, small, high-value target
                    on its own"
 :compiler-findings
 {:deeply-nested-let-fails-with-let-requires-one-result-expression
  {:description "A single check function with ~15 levels of nested
                 (let [x ...] (if ... (let [y ...] (if ... ...)))) failed
                 to compile with \"let requires one result expression\"
                 at a diagnostic span that did not correspond to any
                 actual multi-body let in the source (line/column pointed
                 well past the end of the referenced line) -- the
                 diagnostic location itself looks unreliable for this
                 error, not just the underlying rejection. Isolated by
                 bisection: the same logic split into four independent,
                 shallowly-nested top-level check-a/check-b/check-c/
                 check-wrap functions (each at most 2 let levels)
                 compiles and runs correctly on both targets. Not filed
                 as a compiler issue since the actual trigger (nesting
                 depth? total let count in one function? something else?)
                 was not conclusively isolated -- the workaround (flatten
                 into multiple functions) was sufficient and is arguably
                 better style regardless."
   :compiler-sha "def5161be96d489539175813326a316da46268be"}}
 :verification
 {:legacy {:tests 6 :assertions 19 :failures 0 :errors 0}
  :hand-verified-cases
  "case A matches actor_ipc_test.cljc's game-clock-advance test verbatim
   (tick-rate 60, elapsed 1s -> 60 ticks); cases B/C and the wrap32
   boundary checks were independently computed with a Python
   re-implementation of the identical arithmetic before compiling"
  :web {:main 42 :required-capabilities []}
  :wasm {:main 42}
  :required-capabilities []
  :local-verification
  {:clojure-test {:tests 6 :assertions 19 :failures 0 :errors 0}
   :lint {:errors 0 :warnings 0}
   :kotoba-compile [:js-browser :wasm32-browser]
   :kotoba-conformance :passed-both-targets}}
 :cutover {:bounded-profile-authorized true :general-cljc-oracle-retained true}}
